# Apple Music developer token (JWT) の発行に必要な認証情報。
# Apple Developer Program で取得した値を設定してください。

# Apple Developer の Team ID
APPLE_TEAM_ID=

# MusicKit 対応キーの Key ID
APPLE_KEY_ID=

# .p8 秘密鍵の中身。改行は \n でエスケープして 1 行で記述します。
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# 必須: 待ち受けポート
PORT=1199

# テスト対象のバックエンド URL。テスト実行前に起動済みのサーバーを指定します。
TEST_BACKEND_URL=https://localhost:${PORT}
